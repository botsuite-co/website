---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import Logo from "../assets/botsuite_logo_white.png"
import { Icon } from "astro-icon/components"
---

<header class="padded">
	<nav>
		<h2><a href="/">
			<Image src={Logo} alt="hi" height={64} />
		</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
		<div class="social-links">
			<a href="/join" target="_blank">
				<Icon name="mdi:discord" height={32} width={32} />
			</a>
			<a href="https://www.youtube.com/@botsuite" target="_blank">
				<Icon name="mdi:youtube" height={32} width={32} />
			</a>
			<a href="https://github.com/botsuite-co" target="_blank">
				<Icon name="mdi:github" height={32} width={32} />
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		margin-bottom: 1rem;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
